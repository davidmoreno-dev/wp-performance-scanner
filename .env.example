# =========================================================
# WP Performance Scanner - Environment Variables
# =========================================================
# Copia este archivo como:
#   apps/web/.env.local
#   apps/worker/.env.local
# =========================================================

# --------------------------------------------------
# App URL (necesario para redirects y metadata)
# --------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------
# Supabase
# --------------------------------------------------
# URL del proyecto (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (safe para cliente, expuesta en browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (NUNCA expuesta al cliente, solo server/worker)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------------------------------
# Redis (local) o Upstash (serverless)
# --------------------------------------------------
# Para Upstash: copia la UPSTASH_REDIS_URL desde el dashboard
UPSTASH_REDIS_URL=
# Para Redis local:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# --------------------------------------------------
# BullMQ
# --------------------------------------------------
BULLMQ_SCAN_QUEUE=scan-jobs

# --------------------------------------------------
# Worker
# --------------------------------------------------
WORKER_CONCURRENCY=2
SCAN_TIMEOUT_MS=45000

# --------------------------------------------------
# Node environment
# --------------------------------------------------
NODE_ENV=development
